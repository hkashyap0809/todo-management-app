<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ShopLens — AX Challenge Demo Day</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --ink:    #0b0c10;
    --paper:  #f4f1eb;
    --accent: #e84c1e;
    --teal:   #0d9488;
    --amber:  #d97706;
    --purple: #6d28d9;
    --muted:  #6b6b6b;
    --border: #d4cfc6;
  }

- { margin:0; padding:0; box-sizing:border-box; }

@page { size: A4 landscape; margin: 0; }

body {
width: 297mm;
height: 210mm;
background: var(–paper);
font-family: ‘DM Sans’, sans-serif;
color: var(–ink);
overflow: hidden;
position: relative;
}

/* ── BACKGROUND TEXTURE ── */
body::before {
content:’’;
position:absolute; inset:0;
background-image:
repeating-linear-gradient(0deg, transparent, transparent 28px, #d4cfc620 28px, #d4cfc620 29px),
repeating-linear-gradient(90deg, transparent, transparent 28px, #d4cfc620 28px, #d4cfc620 29px);
pointer-events:none; z-index:0;
}

/* ── LAYOUT GRID ── */
.page {
position: relative; z-index:1;
width: 100%; height: 100%;
display: grid;
grid-template-columns: 62mm 1fr 1fr;
grid-template-rows: 100%;
}

/* ══════════════════════════════════
LEFT SPINE
══════════════════════════════════ */
.spine {
background: var(–ink);
display: flex;
flex-direction: column;
justify-content: space-between;
padding: 7mm 6mm;
position: relative;
overflow: hidden;
}

.spine::after {
content:’’;
position:absolute;
bottom: -20mm; right: -20mm;
width: 60mm; height: 60mm;
border-radius: 50%;
background: var(–accent);
opacity: 0.15;
}

.logo-area {}

.logo-tag {
font-family: ‘DM Mono’, monospace;
font-size: 7.5pt;
color: var(–accent);
letter-spacing: 2px;
text-transform: uppercase;
margin-bottom: 3mm;
}

.logo {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 38pt;
color: #ffffff;
line-height: 0.9;
letter-spacing: 1px;
}

.logo span { color: var(–accent); }

.tagline {
font-size: 7.5pt;
color: #9ca3af;
margin-top: 3mm;
line-height: 1.5;
font-weight: 300;
}

.spine-divider {
height: 1px;
background: #2a2a2a;
margin: 4mm 0;
}

.event-info {}

.event-label {
font-family: ‘DM Mono’, monospace;
font-size: 6.5pt;
color: #555;
letter-spacing: 1.5px;
text-transform: uppercase;
margin-bottom: 2mm;
}

.event-name {
font-size: 9pt;
color: #e5e7eb;
font-weight: 500;
line-height: 1.4;
}

.event-date {
font-family: ‘DM Mono’, monospace;
font-size: 8pt;
color: var(–accent);
margin-top: 1.5mm;
}

.spine-metrics {
display: flex;
flex-direction: column;
gap: 3.5mm;
}

.spine-metric {
border-left: 2px solid var(–accent);
padding-left: 3mm;
}

.spine-metric .val {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 18pt;
color: #fff;
line-height: 1;
}

.spine-metric .val.teal { color: var(–teal); }
.spine-metric .val.amber { color: #fbbf24; }

.spine-metric .lbl {
font-size: 6.5pt;
color: #6b7280;
text-transform: uppercase;
letter-spacing: 1px;
margin-top: 0.5mm;
}

.team-tag {
font-family: ‘DM Mono’, monospace;
font-size: 6pt;
color: #374151;
letter-spacing: 1px;
padding: 2mm 3mm;
border: 1px solid #2a2a2a;
border-radius: 3px;
display: inline-block;
}

/* ══════════════════════════════════
MIDDLE COLUMN
══════════════════════════════════ */
.mid {
border-left: 1px solid var(–border);
border-right: 1px solid var(–border);
display: flex;
flex-direction: column;
padding: 6mm 6mm;
gap: 0;
}

/* ── SECTION HEADER ── */
.s-head {
display: flex;
align-items: center;
gap: 2.5mm;
margin-bottom: 2.5mm;
}

.s-num {
font-family: ‘DM Mono’, monospace;
font-size: 6.5pt;
color: var(–accent);
background: #fde8e0;
padding: 0.5mm 2mm;
border-radius: 2px;
letter-spacing: 1px;
}

.s-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 12pt;
letter-spacing: 1px;
color: var(–ink);
}

.section { margin-bottom: 4.5mm; }

.section:last-child { margin-bottom: 0; }

.section p, .section li {
font-size: 7.5pt;
line-height: 1.55;
color: #2d2d2d;
font-weight: 400;
}

.section ul {
padding-left: 3.5mm;
list-style: none;
}

.section ul li::before {
content: ‘→’;
color: var(–accent);
margin-right: 1.5mm;
font-size: 7pt;
}

.hr { height:1px; background: var(–border); margin: 4mm 0; }

/* Problem pills */
.pill-row {
display: flex;
flex-wrap: wrap;
gap: 2mm;
margin-top: 2mm;
}

.pill {
font-size: 6.5pt;
padding: 1.5mm 3mm;
border-radius: 20px;
font-weight: 500;
letter-spacing: 0.3px;
}

.pill.red { background:#fde8e0; color: var(–accent); border:1px solid #f9c4b0; }
.pill.teal { background:#ccfbf1; color: #0f766e; border:1px solid #99f6e4; }
.pill.amber { background:#fef3c7; color: #92400e; border:1px solid #fde68a; }
.pill.purple { background:#ede9fe; color: #5b21b6; border:1px solid #c4b5fd; }

/* Tech stack chips */
.chip-row {
display: flex;
flex-wrap: wrap;
gap: 1.5mm;
margin-top: 2mm;
}

.chip {
font-family: ‘DM Mono’, monospace;
font-size: 6pt;
padding: 1mm 2mm;
background: var(–ink);
color: #d1d5db;
border-radius: 2px;
letter-spacing: 0.5px;
}

.chip.hi { background: var(–teal); color:#fff; }

/* Why AI box */
.why-box {
background: var(–ink);
border-radius: 4px;
padding: 3mm 4mm;
margin-top: 2mm;
}

.why-box p {
color: #d1d5db !important;
font-size: 7pt !important;
line-height: 1.55 !important;
}

.why-box strong { color: #fbbf24; }

/* ══════════════════════════════════
RIGHT COLUMN
══════════════════════════════════ */
.right {
display: flex;
flex-direction: column;
padding: 6mm 6mm;
gap: 0;
}

/* Use case cards */
.uc-card {
border: 1px solid var(–border);
border-radius: 5px;
padding: 4mm;
margin-bottom: 3.5mm;
position: relative;
overflow: hidden;
}

.uc-card::before {
content: ‘’;
position: absolute;
top:0; left:0;
width:3px; height:100%;
}

.uc-card.uc1::before { background: var(–accent); }
.uc-card.uc2::before { background: var(–teal); }

.uc-num {
font-family: ‘DM Mono’, monospace;
font-size: 6pt;
color: var(–muted);
letter-spacing: 2px;
text-transform: uppercase;
margin-bottom: 1.5mm;
}

.uc-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 11pt;
letter-spacing: 0.5px;
margin-bottom: 2mm;
color: var(–ink);
}

.uc-card p {
font-size: 7.5pt;
line-height: 1.5;
color: #3d3d3d;
}

.uc-flow {
display: flex;
align-items: center;
gap: 1.5mm;
margin-top: 2.5mm;
flex-wrap: wrap;
}

.uc-step {
font-size: 6pt;
padding: 1mm 2.5mm;
border-radius: 2px;
font-weight: 500;
white-space: nowrap;
}

.uc1 .uc-step { background:#fde8e0; color: var(–accent); }
.uc2 .uc-step { background:#ccfbf1; color: #0f766e; }

.uc-arrow {
font-size: 7pt;
color: var(–muted);
}

/* Quant benefits grid */
.quant-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 2.5mm;
margin-top: 2mm;
}

.q-cell {
border: 1px solid var(–border);
border-radius: 4px;
padding: 3mm;
position: relative;
}

.q-cell::after {
content: ‘’;
position: absolute;
bottom:0; right:0;
width: 8mm; height: 8mm;
border-radius: 50% 0 4px 0;
opacity: 0.08;
}

.q-cell.c1::after { background: var(–accent); }
.q-cell.c2::after { background: var(–teal); }
.q-cell.c3::after { background: var(–amber); }
.q-cell.c4::after { background: var(–purple); }

.q-icon {
font-size: 9pt;
margin-bottom: 1.5mm;
display: block;
}

.q-val {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 17pt;
line-height: 1;
color: var(–ink);
}

.q-cell.c1 .q-val { color: var(–accent); }
.q-cell.c2 .q-val { color: var(–teal); }
.q-cell.c3 .q-val { color: var(–amber); }
.q-cell.c4 .q-val { color: var(–purple); }

.q-sub {
font-size: 6.5pt;
color: var(–muted);
margin-top: 1mm;
line-height: 1.4;
}

.q-label {
font-family: ‘DM Mono’, monospace;
font-size: 6pt;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 1px;
margin-top: 1.5mm;
}

/* bottom strip */
.bottom-strip {
margin-top: auto;
padding-top: 3mm;
border-top: 1px solid var(–border);
display: flex;
justify-content: space-between;
align-items: flex-end;
}

.commercialize {
font-size: 7pt;
color: var(–muted);
}

.commercialize strong {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 13pt;
color: var(–ink);
display: block;
line-height: 1;
}

.commercialize em {
font-style: normal;
color: var(–teal);
font-weight: 600;
}

.watermark {
font-family: ‘DM Mono’, monospace;
font-size: 5.5pt;
color: #c0bbb0;
letter-spacing: 1px;
text-align: right;
}

</style>
</head>
