<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>ShopLens</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0a0a12;
      font-family: 'Segoe UI', system-ui, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 24px;
    }
    svg { width: 100%; max-width: 820px; height: auto; display: block; }
  </style>
</head>
<body>
<svg viewBox="0 0 820 540" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <pattern id="g" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M40 0L0 0 0 40" fill="none" stroke="#ffffff06" stroke-width="0.5"/>
    </pattern>
    <linearGradient id="hg" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#7c3aed"/>
      <stop offset="50%" stop-color="#0d9488"/>
      <stop offset="100%" stop-color="#d97706"/>
    </linearGradient>
    <marker id="a" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#ffffff25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="ag" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#22c55e60" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="aa" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#d9770660" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="at" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#0d9488" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  </defs>

  <!-- BG -->
  <rect width="820" height="540" fill="#0f0f1a"/>
  <rect width="820" height="540" fill="url(#g)"/>

  <!-- Header -->
  <rect width="820" height="46" fill="#13131f"/>
  <rect y="43" width="820" height="2.5" fill="url(#hg)"/>
  <text font-size="20" font-weight="700" fill="#fff" x="30" y="28">ShopLens</text>
  <text font-size="9" fill="#6b7280" x="30" y="40">See It · Buy It · Own It</text>
  <text font-size="9" font-weight="600" fill="#a78bfa" x="792" y="26" text-anchor="end">HACKATHON BUILD</text>

  <!-- ── DISCOVERY ── -->
  <text font-size="8" font-weight="700" fill="#4b5563" letter-spacing="2" x="30" y="62">DISCOVERY</text>

  <!-- Video -->
  <rect x="30" y="67" width="356" height="46" rx="8" fill="#1a0f0f" stroke="#dc2626" stroke-width="0.8"/>
  <rect x="30" y="67" width="356" height="2.5" rx="2" fill="#dc2626" opacity="0.8"/>
  <text font-size="11" font-weight="700" fill="#fca5a5" x="208" y="86" text-anchor="middle">📺  Video Player</text>
  <text font-size="9" fill="#6b7280" x="208" y="103" text-anchor="middle">YOLOv8 / CLIP detects objects → shoppable overlay</text>

  <!-- Chat -->
  <rect x="434" y="67" width="356" height="46" rx="8" fill="#1a1830" stroke="#4f46e5" stroke-width="0.8"/>
  <rect x="434" y="67" width="356" height="2.5" rx="2" fill="#4f46e5" opacity="0.8"/>
  <text font-size="11" font-weight="700" fill="#a5b4fc" x="612" y="86" text-anchor="middle">🎙  Chat / Voice</text>
  <text font-size="9" fill="#6b7280" x="612" y="103" text-anchor="middle">User prompts → natural language product search</text>

  <line x1="208" y1="113" x2="208" y2="129" stroke="#dc262640" stroke-width="1.2" stroke-dasharray="3 2" marker-end="url(#a)"/>
  <line x1="612" y1="113" x2="612" y2="129" stroke="#4f46e540" stroke-width="1.2" stroke-dasharray="3 2" marker-end="url(#a)"/>

  <!-- ── UCP GATEWAY ── -->
  <rect x="30" y="131" width="760" height="44" rx="8" fill="#0d1117" stroke="#a78bfa" stroke-width="1.2"/>
  <rect x="30" y="131" width="760" height="2.5" rx="2" fill="#7c3aed" opacity="0.9"/>
  <rect x="30" y="131" width="760" height="44" rx="8" fill="#7c3aed" opacity="0.04"/>
  <text font-size="13" font-weight="700" fill="#c4b5fd" x="410" y="151" text-anchor="middle">⚡  UCP GATEWAY</text>
  <text font-size="8" fill="#4b5563" x="410" y="167" text-anchor="middle">capability negotiation  ·  merchant routing  ·  session management  ·  request signing</text>

  <line x1="410" y1="175" x2="410" y2="191" stroke="#a78bfa35" stroke-width="1.2" marker-end="url(#a)"/>

  <!-- ── PRODUCTS DISCOVERED ── -->
  <rect x="180" y="193" width="460" height="36" rx="8" fill="#081814" stroke="#0d9488" stroke-width="1"/>
  <rect x="180" y="193" width="460" height="2.5" rx="2" fill="#0d9488" opacity="0.8"/>
  <text font-size="11" font-weight="700" fill="#5eead4" x="410" y="210" text-anchor="middle">🔍  Products discovered across merchants</text>
  <text font-size="8" fill="#6b7280" x="410" y="223" text-anchor="middle">name · price · merchant · availability</text>

  <!-- Split -->
  <line x1="410" y1="229" x2="410" y2="244" stroke="#ffffff10" stroke-width="1"/>
  <line x1="185" y1="244" x2="635" y2="244" stroke="#ffffff10" stroke-width="1"/>
  <circle cx="410" cy="244" r="2.5" fill="#ffffff15"/>
  <text font-size="8" font-weight="700" fill="#86efac" x="185" y="241" text-anchor="middle">BUY NOW</text>
  <text font-size="8" font-weight="700" fill="#fcd34d" x="635" y="241" text-anchor="middle">AUTO-BUY</text>
  <line x1="185" y1="244" x2="185" y2="257" stroke="#22c55e40" stroke-width="1.2" marker-end="url(#ag)"/>
  <line x1="635" y1="244" x2="635" y2="257" stroke="#d9770640" stroke-width="1.2" marker-end="url(#aa)"/>

  <!-- ── BUY NOW ── -->
  <rect x="30" y="259" width="310" height="36" rx="8" fill="#0a160a" stroke="#22c55e" stroke-width="0.8"/>
  <text font-size="10" font-weight="600" fill="#86efac" x="185" y="275" text-anchor="middle">✅  User confirms purchase</text>
  <text font-size="8" fill="#6b7280" x="185" y="289" text-anchor="middle">UCP creates session → routes to adapter</text>

  <line x1="185" y1="295" x2="185" y2="309" stroke="#22c55e35" stroke-width="1.2" stroke-dasharray="3 2" marker-end="url(#ag)"/>

  <!-- Merged: Payment + Order Placed -->
  <rect x="30" y="311" width="310" height="40" rx="8" fill="#052e16" stroke="#16a34a" stroke-width="1.2"/>
  <text font-size="10" font-weight="700" fill="#4ade80" x="185" y="328" text-anchor="middle">💳  Payment → 🎉 Order Placed</text>
  <text font-size="8" fill="#6b7280" x="185" y="343" text-anchor="middle">Single Checkout · end-to-end</text>

  <!-- ── AUTO-BUY ── -->
  <rect x="480" y="259" width="310" height="36" rx="8" fill="#1a140a" stroke="#d97706" stroke-width="0.8"/>
  <text font-size="10" font-weight="600" fill="#fcd34d" x="635" y="275" text-anchor="middle">📌  User sets price threshold</text>
  <text font-size="8" fill="#6b7280" x="635" y="289" text-anchor="middle">"Buy when price drops below ₹1500"</text>

  <line x1="635" y1="295" x2="635" y2="309" stroke="#d9770635" stroke-width="1.2" stroke-dasharray="3 2" marker-end="url(#aa)"/>

  <!-- Merged: Watcher + Order Placed + Notified -->
  <rect x="480" y="311" width="310" height="40" rx="8" fill="#1a0f00" stroke="#b45309" stroke-width="1.2"/>
  <text font-size="10" font-weight="700" fill="#fbbf24" x="635" y="328" text-anchor="middle">⚡  Price drops → 🎉 Order + Notified</text>
  <text font-size="8" fill="#6b7280" x="635" y="343" text-anchor="middle">Auto checkout fires · buyer notified</text>

  <!-- ── ADAPTERS ── -->
  <line x1="30" y1="370" x2="790" y2="370" stroke="#1f2937" stroke-width="1"/>
  <text font-size="8" font-weight="700" fill="#4b5563" letter-spacing="2" x="30" y="384">MERCHANT ADAPTERS</text>

  <!-- SingleStore with mini flow -->
  <rect x="30" y="390" width="458" height="90" rx="8" fill="#0d1117" stroke="#0d9488" stroke-width="1.2"/>
  <rect x="30" y="390" width="458" height="2.5" rx="2" fill="#0d9488" opacity="0.7"/>
  <text font-size="11" font-weight="700" fill="#5eead4" x="259" y="408" text-anchor="middle">SingleStore  +  Single Checkout</text>
  <!-- mini flow boxes -->
  <rect x="46" y="416" width="88" height="30" rx="5" fill="#0a1a18" stroke="#0d9488" stroke-width="0.7"/>
  <text font-size="8" font-weight="600" fill="#5eead4" x="90" y="429" text-anchor="middle">Product</text>
  <text font-size="8" fill="#9ca3af" x="90" y="441" text-anchor="middle">Discovery</text>
  <line x1="134" y1="431" x2="148" y2="431" stroke="#0d9488" stroke-width="0.8" marker-end="url(#at)"/>

  <rect x="150" y="416" width="88" height="30" rx="5" fill="#0a1a18" stroke="#0d9488" stroke-width="0.7"/>
  <text font-size="8" font-weight="600" fill="#5eead4" x="194" y="429" text-anchor="middle">UCP Match</text>
  <text font-size="8" fill="#9ca3af" x="194" y="441" text-anchor="middle">Catalog sync</text>
  <line x1="238" y1="431" x2="252" y2="431" stroke="#0d9488" stroke-width="0.8" marker-end="url(#at)"/>

  <rect x="254" y="416" width="104" height="30" rx="5" fill="#0a1a18" stroke="#5eead4" stroke-width="1"/>
  <text font-size="8" font-weight="700" fill="#5eead4" x="306" y="429" text-anchor="middle">Single Checkout</text>
  <text font-size="8" fill="#9ca3af" x="306" y="441" text-anchor="middle">Payment end-to-end</text>
  <line x1="358" y1="431" x2="372" y2="431" stroke="#0d9488" stroke-width="0.8" marker-end="url(#at)"/>

  <rect x="374" y="416" width="98" height="30" rx="5" fill="#052e16" stroke="#22c55e" stroke-width="0.8"/>
  <text font-size="8" font-weight="700" fill="#4ade80" x="423" y="431" text-anchor="middle">Order Placed ✓</text>

  <!-- Merchant 2 -->
  <rect x="506" y="390" width="148" height="90" rx="8" fill="#0d1117" stroke="#0d9488" stroke-width="1"/>
  <text font-size="11" font-weight="600" fill="#5eead4" x="580" y="412" text-anchor="middle">Merchant 2</text>
  <text font-size="9" fill="#6b7280" x="580" y="430" text-anchor="middle">Pre-integrated</text>
  <text font-size="8" fill="#374151" x="580" y="448" text-anchor="middle">Custom adapter</text>

  <!-- New Merchant -->
  <rect x="672" y="390" width="118" height="90" rx="8" fill="#0d1117" stroke="#4f46e5" stroke-width="0.8" stroke-dasharray="5 3"/>
  <text font-size="11" font-weight="600" fill="#a5b4fc" x="731" y="412" text-anchor="middle">+ Merchant</text>
  <text font-size="9" fill="#6b7280" x="731" y="430" text-anchor="middle">Any platform</text>
  <text font-size="8" fill="#4f46e5" x="731" y="448" text-anchor="middle">Register via portal</text>

  <!-- Footer -->
  <rect y="496" width="820" height="44" fill="#13131f"/>
  <text font-size="9" fill="#374151" x="410" y="522" text-anchor="middle">One UCP integration · Any merchant · Any surface · Any buying moment</text>
</svg>
</body>
</html>
